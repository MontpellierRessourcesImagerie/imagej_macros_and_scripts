
macro "Unpack images Action Tool - " {
	run("ami decapsulate x1");
}

macro "Initialize workspace Action Tool - " {
	run("ami setup workspace");
}

macro "Filter by size Action Tool - " {
	run("ami filter by size");	
}

macro "Merge labels Action Tool - " {
	run("ami merge labels");
}

macro "Remove labels Action Tool - " {
	run("ami remove labels");
}

macro "Cut labels Action Tool - " {
	setForegroundColor(0, 0, 0);
	setBackgroundColor(255, 255, 255);
	run("Draw", "stack");
	original = getImageID();
	run("Connected Components Labeling", "connectivity=6 type=[16 bits]");
	selectImage(original);
	close();
}

macro "Random LUT Action Tool - " {
	_max = 0;
	_min = 65536;
	for (i=1; i<=nSlices; i++) {
	    setSlice(i);
	    getStatistics(area, mean, min, max, std, histogram);
	    if (min < _min) { _min = min; }
	    if (max > _max) { _max = max; }
	}
	setMinAndMax(0, _max+1);
	run("glasbey on dark");
}